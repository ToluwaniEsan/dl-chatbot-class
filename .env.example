# OpenAI-compatible API (OpenAI, Azure OpenAI-compatible, Groq, Together, etc.)
# For local Ollama: OPENAI_BASE_URL=http://localhost:11434/v1 and OPENAI_API_KEY=ollama (dummy)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Optional: embeddings for RAG (OpenAI: text-embedding-3-small; Ollama: e.g. nomic-embed-text)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Generation defaults
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=512

# Optional: override system prompt
# LLM_SYSTEM_PROMPT=You are a helpful teaching assistant.

# RAG (optional): .md / .txt files under this folder
RAG_CORPUS_DIR=data/corpus
RAG_CHUNK_CHARS=900
RAG_CHUNK_OVERLAP=120
RAG_TOP_K=4
