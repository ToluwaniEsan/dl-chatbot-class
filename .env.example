# OpenAI-compatible API (OpenAI, Azure OpenAI-compatible, Groq, Together, DeepSeek, etc.)
# For local Ollama: OPENAI_BASE_URL=http://localhost:11434/v1 and OPENAI_API_KEY=ollama (dummy)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# DeepSeek (chat only — same OpenAI SDK; get a key at https://platform.deepseek.com/api_keys):
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat
# (Optional reasoning model: deepseek-reasoner — use a large LLM_MAX_TOKENS; the app floors at 16384 for reasoning / Qwen3 / r1-style ids.)

# Embeddings for RAG: use the same provider as chat, OR override when chat has no embedding API
# (DeepSeek does not publish an OpenAI-compatible embeddings endpoint — use OpenAI/Ollama here.)
# OPENAI_EMBEDDING_BASE_URL=https://api.openai.com/v1
# OPENAI_EMBEDDING_API_KEY=sk-...   # can differ from OPENAI_API_KEY
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Generation defaults
LLM_TEMPERATURE=0.7
# Use 16384+ for reasoning / Qwen3 / deepseek-reasoner (thinking + answer share this budget).
LLM_MAX_TOKENS=16384
# Ollama thinking models: default is think=false for Qwen3 so replies use `content`. Set LLM_THINK=true to enable traces.
# LLM_THINK=false

# Optional: override system prompt
# LLM_SYSTEM_PROMPT=You are a helpful teaching assistant.

# RAG: omit or true = retrieve from corpus. Use false, 0, or off for model-only (no embeddings).
# RAG_ENABLED=false

# Multimodal (images + uploads): the chat UI sends images and files. Use a vision-capable model
# for images (e.g. Ollama: llava, qwen2.5vl). Text/PDF content works with any chat model.
RAG_CORPUS_DIR=data/corpus
RAG_CHUNK_CHARS=900
RAG_CHUNK_OVERLAP=120
RAG_TOP_K=4
