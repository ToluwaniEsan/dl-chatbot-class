# Chat provider config (Groq default)
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.1-8b-instant

# Optional: web search integration via Tavily (free tier: 1000 calls/month)
# Sign up at tavily.com to get your API key
# TAVILY_API_KEY=

# Generation defaults
LLM_TEMPERATURE=0.7
# Use 16384+ for reasoning / Qwen3 / deepseek-reasoner (thinking + answer share this budget).
LLM_MAX_TOKENS=16384
# Ollama thinking models: default is think=false for Qwen3 so replies use `content`. Set LLM_THINK=true to enable traces.
# LLM_THINK=false

# Optional: override system prompt
# LLM_SYSTEM_PROMPT=You are a helpful teaching assistant.
